GOBA_APP_ENVIRONMENT=development
GOBA_SERVER_HOST=0.0.0.0
GOBA_SERVER_PORT=8000
# task setup 会在本地 .env 中生成随机密码；示例文件不提供 Secret。
GOBA_DATABASE_PASSWORD=
GOBA_REDIS_PASSWORD=
# 本地私钥由 task setup 或 task auth:keygen 生成，生产环境应使用平台 Secret。
GOBA_AUTH_PRIVATE_KEY_FILE=configs/auth-private.local.pem
# 旧 kid 与 PKIX 公钥文件，多个值使用英文逗号分隔，例如 old=/run/secrets/old-public.pem。
GOBA_AUTH_VERIFICATION_KEY_FILES=
# 可选文件模块配置；默认关闭模块，启用后需要确保目录可写。
GOBA_MODULES_FILE=false
GOBA_FILE_STORAGE_PATH=var/uploads
GOBA_FILE_IMAGE_MAX_BYTES=5242880
GOBA_FILE_VIDEO_ENABLED=false
GOBA_FILE_VIDEO_MAX_BYTES=104857600
GOBA_MODULES_SYSTEMCONFIG=false
GOBA_SYSTEMCONFIG_CACHE_TTL=5m
# Linux/macOS 直接运行 docker compose up 时设置为 id -u / id -g；task compose:up 会自动设置。
# GOBA_CONTAINER_UID=1000
# GOBA_CONTAINER_GID=1000
