GOBA_APP_ENVIRONMENT=development
GOBA_SERVER_HOST=0.0.0.0
GOBA_SERVER_PORT=8000
# task setup 会在本地 .env 中生成随机密码；示例文件不提供 Secret。
GOBA_DATABASE_PASSWORD=
GOBA_REDIS_PASSWORD=
# 本地私钥由 task setup 或 task auth:keygen 生成，生产环境应使用平台 Secret。
GOBA_AUTH_PRIVATE_KEY_FILE=configs/auth-private.local.pem
# 旧 kid 与 PKIX 公钥文件，多个值使用英文逗号分隔，例如 old=/run/secrets/old-public.pem。
GOBA_AUTH_VERIFICATION_KEY_FILES=
