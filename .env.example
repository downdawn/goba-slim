GOBA_APP_ENVIRONMENT=development
GOBA_SERVER_HOST=0.0.0.0
GOBA_SERVER_PORT=8000
# 二选一：GOBA_DATABASE_PASSWORD 或 GOBA_DATABASE_PASSWORD_FILE；示例不提供密码。
GOBA_DATABASE_PASSWORD_FILE=
# 二选一：GOBA_REDIS_PASSWORD 或 GOBA_REDIS_PASSWORD_FILE；无密码 Redis 可留空。
GOBA_REDIS_PASSWORD_FILE=
# 二选一：GOBA_AUTH_PRIVATE_KEY 或 GOBA_AUTH_PRIVATE_KEY_FILE；生产环境推荐后者。
GOBA_AUTH_PRIVATE_KEY_FILE=
